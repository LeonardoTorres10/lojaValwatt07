<div class="max-w-4xl mx-auto py-12 px-4">
  <h1 class="text-3xl font-bold text-[#0D3B8C] mb-8">Seu Carrinho</h1>
  {% if cart.item_count > 0 %}
    <form action="/cart" method="post" class="bg-white p-6 rounded-2xl shadow-sm border">
      {% for item in cart.items %}
        <div class="flex items-center justify-between border-b pb-4 mb-4">
          <div class="flex items-center gap-4">
            <img src="{{ item.image | img_url: '100x' }}" alt="{{ item.title }}" class="w-20 h-20 object-cover rounded">
            <div>
              <h3 class="font-bold text-gray-800">{{ item.product.title }}</h3>
              <p class="text-gray-500">{{ item.price | money }}</p>
            </div>
          </div>
          <div>
            <input type="number" name="updates[]" value="{{ item.quantity }}" class="w-16 border rounded p-2 text-center" min="0">
          </div>
        </div>
      {% endfor %}
      <div class="flex justify-between items-center mt-6">
        <h3 class="text-2xl font-bold">Subtotal: {{ cart.total_price | money }}</h3>
        <div>
          <button type="submit" name="update" class="bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-3 px-6 rounded-xl mr-4">Atualizar</button>
          <button type="submit" name="checkout" class="bg-[#0D3B8C] hover:bg-blue-800 text-white font-bold py-3 px-8 rounded-xl shadow-md">Finalizar Compra</button>
        </div>
      </div>
    </form>
  {% else %}
    <p class="text-gray-500 text-lg">Seu carrinho está vazio. <a href="/collections/all" class="text-[#0D3B8C] underline font-bold">Continuar comprando</a>.</p>
  {% endif %}
</div>

{% schema %}
{
  "name": "Carrinho Principal",
  "settings": []
}
{% endschema %}
