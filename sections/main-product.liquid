<div class="max-w-7xl mx-auto py-12 px-4 grid grid-cols-1 md:grid-cols-2 gap-8">
  <div>
    <img src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title }}" class="w-full rounded-2xl shadow-md border">
  </div>
  <div>
    <h1 class="text-4xl font-bold text-[#0D3B8C] mb-4">{{ product.title }}</h1>
    <p class="text-3xl font-bold text-yellow-500 mb-6">{{ product.price | money }}</p>
    <div class="prose mb-8 text-gray-700">
      {{ product.description }}
    </div>
    
    {% form 'product', product %}
      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
      <button type="submit" class="bg-[#0D3B8C] hover:bg-blue-800 text-white font-bold py-4 px-8 rounded-xl w-full text-lg shadow-lg">Adicionar ao Carrinho</button>
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "Produto Principal",
  "settings": []
}
{% endschema %}
